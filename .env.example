# StableLobster Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/stablelobster.db

# Security
# Generate a random 32-byte hex string for this
INSTALL_ID_SALT=your_random_salt_here_32_bytes_hex
# Generate a random 32-byte hex string for admin auth
ADMIN_PASSWORD_HASH=your_admin_password_hash_here

# GitHub API (optional, for release scraping)
GITHUB_TOKEN=your_github_token_here

# WebSocket
WS_ORIGIN=https://stablelobster.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10
